{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeepGYM",
  "version": "0.1.0",
  "identifier": "com.deepgym.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeepGYM",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://raw.githubusercontent.com data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420 https://*.supabase.co wss://*.supabase.co"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:deepgym.db"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Healthcare and Fitness",
    "shortDescription": "健身动作指导与训练记录",
    "longDescription": "DeepGYM 为健身人士提供动作动图、中文步骤、训练记录与每日总结。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
